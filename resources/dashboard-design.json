{
    "design_system_name": "ROOMAH CRM Dashboard",
    "design_philosophy": {
      "style": "Modern SaaS CRM",
      "personality": [
        "Professional",
        "Trustworthy",
        "Minimal",
        "Productivity-focused",
        "Data-driven"
      ],
      "principles": [
        "Actions before analytics",
        "High information density without clutter",
        "Clear visual hierarchy",
        "Consistent spacing",
        "Card-based organization",
        "Dashboard-first workflow",
        "Enterprise SaaS patterns",
        "Minimal visual noise"
      ]
    },
  
    "layout": {
      "type": "Desktop Application Shell",
      "max_width": "Full Width",
      "structure": {
        "sidebar": {
          "position": "left",
          "width": "260px",
          "fixed": true,
          "full_height": true
        },
        "topbar": {
          "height": "72px",
          "sticky": true,
          "full_width": true
        },
        "content": {
          "padding": "24px",
          "scrollable": true
        }
      }
    },
  
    "grid_system": {
      "content_width": "fluid",
      "base_spacing": 8,
      "section_gap": 16,
      "card_gap": 16,
      "page_padding": 24,
      "card_padding": 20,
      "border_radius": {
        "small": 8,
        "medium": 12,
        "large": 16
      }
    },
  
    "color_system": {
      "primary": "#00D4FF",
      "primary_dark": "#0B1F3A",
      "primary_gradient": {
        "start": "#0B1F3A",
        "end": "#102A4D"
      },
      "background": "#F8FAFC",
      "surface": "#FFFFFF",
      "border": "#E5E7EB",
      "text": {
        "primary": "#111827",
        "secondary": "#6B7280",
        "muted": "#9CA3AF"
      },
      "status": {
        "success": "#22C55E",
        "warning": "#F59E0B",
        "danger": "#EF4444",
        "info": "#3B82F6"
      }
    },
  
    "typography": {
      "font_family": "Inter",
      "weights": {
        "regular": 400,
        "medium": 500,
        "semibold": 600,
        "bold": 700
      },
      "sizes": {
        "page_title": "32px",
        "section_title": "24px",
        "card_title": "18px",
        "body": "14px",
        "small": "12px",
        "caption": "11px"
      }
    },
  
    "sidebar": {
      "style": "Dark Gradient Navigation",
      "background": "vertical-gradient",
      "logo_position": "top",
      "logo_alignment": "left",
      "navigation_group": {
        "position": "upper"
      },
      "utility_group": {
        "position": "bottom"
      },
      "navigation_items": {
        "height": "48px",
        "icon_left": true,
        "label_visible": true,
        "active_state": {
          "left_indicator": true,
          "highlight_background": true,
          "accent_color": "primary"
        },
        "hover_state": {
          "background_opacity": "subtle"
        }
      },
      "collapsed_mode": {
        "icons_only": true,
        "preserve_active_indicator": true
      }
    },
  
    "topbar": {
      "background": "#FFFFFF",
      "border_bottom": true,
      "layout": {
        "left": [
          "sidebar_toggle",
          "global_search"
        ],
        "right": [
          "notifications",
          "calendar",
          "create_menu",
          "user_profile"
        ]
      },
      "search": {
        "shape": "pill",
        "width": "large",
        "shortcut_hint": true
      }
    },
  
    "page_structure": {
      "header": {
        "contains": [
          "page_title",
          "page_description",
          "page_actions"
        ]
      },
  
      "section_order": [
        "header",
        "action_panel",
        "kpi_cards",
        "primary_workspace",
        "secondary_insights"
      ]
    },
  
    "dashboard_pattern": {
      "row_1": {
        "layout": "2-column",
        "left": "task_widget",
        "right": "quick_actions"
      },
  
      "row_2": {
        "layout": "5-card-grid",
        "component": "kpi_cards"
      },
  
      "row_3": {
        "layout": "2-column",
        "ratio": "60/40",
        "left": "primary_table",
        "right": "activity_feed"
      },
  
      "row_4": {
        "layout": "2-column",
        "ratio": "50/50",
        "left": "pipeline_summary",
        "right": "secondary_table"
      }
    },
  
    "cards": {
      "style": "Soft Enterprise",
      "background": "#FFFFFF",
      "border": "1px solid #E5E7EB",
      "radius": "12px",
      "shadow": "subtle",
      "padding": "20px",
      "header": {
        "title_left": true,
        "actions_right": true
      }
    },
  
    "kpi_cards": {
      "layout": "horizontal",
      "count": 5,
      "structure": {
        "icon": "left",
        "metric": "center",
        "trend": "bottom"
      },
      "visual_weight": "medium"
    },
  
    "tables": {
      "style": "CRM Data Grid",
      "header_background": "#FFFFFF",
      "row_height": "comfortable",
      "borders": "horizontal_only",
      "actions": "minimal",
      "status_badges": true
    },
  
    "timeline": {
      "layout": "vertical",
      "line_visible": true,
      "event_icon": true,
      "timestamp_alignment": "right",
      "event_density": "compact"
    },
  
    "pipeline_visualization": {
      "type": "stage_progression",
      "orientation": "horizontal",
      "stages_connected": true,
      "card_style": true,
      "show_counts": true
    },
  
    "buttons": {
      "primary": {
        "shape": "rounded",
        "background": "accent",
        "text_color": "white"
      },
      "secondary": {
        "outline": true
      },
      "quick_action": {
        "card_based": true,
        "large_icon": true,
        "vertical_alignment": true
      }
    },
  
    "forms": {
      "input_style": "rounded",
      "label_position": "top",
      "spacing": "comfortable",
      "wizard_preferred": true
    },
  
    "interaction_patterns": {
      "navigation": "sidebar",
      "creation": "global_create_button",
      "search": "global_search_bar",
      "notifications": "top_right",
      "profile_access": "top_right_avatar",
      "page_actions": "header_right"
    },
  
    "responsive_behavior": {
      "desktop": {
        "sidebar": "expanded",
        "multi_column": true
      },
      "tablet": {
        "sidebar": "collapsible",
        "reduce_columns": true
      },
      "mobile": {
        "sidebar": "drawer",
        "single_column": true,
        "cards_stack": true
      }
    },
  
    "component_patterns": {
      "dashboard": {
        "priority": [
          "tasks",
          "actions",
          "kpis",
          "work_queue",
          "analytics"
        ]
      },
  
      "list_pages": {
        "structure": [
          "page_header",
          "filters",
          "table",
          "pagination"
        ]
      },
  
      "detail_pages": {
        "structure": [
          "summary_header",
          "overview_cards",
          "activity_timeline",
          "related_records"
        ]
      },
  
      "create_pages": {
        "structure": [
          "stepper",
          "form_sections",
          "review_screen"
        ]
      }
    },
  
    "ux_rules": [
      "Always place primary actions above analytics.",
      "Use cards to separate information domains.",
      "Never place more than 2 major content columns side-by-side.",
      "Keep KPI cards visually consistent across all pages.",
      "Use timelines for activity history.",
      "Use status badges instead of coloured text.",
      "Maintain 8px spacing system throughout.",
      "Keep global actions accessible from top navigation.",
      "Use white surfaces against light grey page background.",
      "Maintain enterprise CRM visual consistency across modules."
    ],
  
    "do_not_copy": [
      "Specific data values",
      "Specific names",
      "Specific metrics",
      "Specific property records",
      "Specific timeline entries",
      "Specific images",
      "Specific logos",
      "Example table contents"
    ]
  }
APP_ENV=local

# Comma-separated list of explicit frontend origins allowed by CORS.
# Production example:
# FRONTEND_ORIGIN=https://roomah-demo.netlify.app
FRONTEND_ORIGIN=http://localhost:3000

# Optional regex for Netlify deploy preview origins. Set this after the final
# Netlify site slug is known.
# Example:
# FRONTEND_ORIGIN_REGEX=^https://deploy-preview-[0-9]+--roomah-demo\.netlify\.app$
FRONTEND_ORIGIN_REGEX=

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_JWT_AUDIENCE=authenticated

DEFAULT_TEAM_ID=00000000-0000-4000-8000-000000000001

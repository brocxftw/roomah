{
    "design_system_name": "ROOMAH CRM - Manager Performance Workspace",
  
    "design_style": {
      "category": "Modern SaaS CRM",
      "subtype": "Management and Team Performance Workspace",
      "personality": [
        "Executive",
        "Data-driven",
        "Operational",
        "Professional",
        "Performance-focused",
        "Leadership-oriented"
      ],
      "visual_characteristics": [
        "Executive dashboard layout",
        "Analytics-first information hierarchy",
        "Master-detail architecture",
        "Card-based composition",
        "Soft enterprise styling",
        "Minimal shadows",
        "High readability",
        "Structured visual hierarchy",
        "Balanced analytics and operational insights"
      ]
    },
  
    "design_philosophy": {
      "primary_goal": "Provide managers with immediate visibility into team performance, pipeline health, commissions, and operational risks.",
  
      "ux_principles": [
        "Performance before activity.",
        "Insights before details.",
        "Team management without page switching.",
        "Metrics should support decision-making.",
        "Analytics should remain simple and actionable.",
        "The selected team member should always remain visible."
      ]
    },
  
    "page_archetype": {
      "type": "Executive Dashboard + Team Management Workspace",
      "purpose": "Monitor team performance, identify bottlenecks, manage agents, and review operational metrics from a single screen.",
      "interaction_model": "Review Team Metrics → Identify Opportunities → Select Team Member → Take Action"
    },
  
    "layout": {
      "type": "Three-Panel Executive Workspace",
  
      "left_panel": {
        "role": "Global Navigation",
        "width": "240-260px",
        "fixed": true
      },
  
      "center_panel": {
        "role": "Management Dashboard",
        "width": "fluid",
        "priority": "highest"
      },
  
      "right_panel": {
        "role": "Team Member Detail Drawer",
        "width": "340-380px",
        "sticky": true,
        "fixed": true
      }
    },
  
    "color_system": {
      "navigation": {
        "background": "#0B1F3A",
        "gradient_start": "#0B1F3A",
        "gradient_end": "#102A4D",
        "active_item": "#00D4FF",
        "text": "#FFFFFF"
      },
  
      "brand": {
        "primary": "#00D4FF",
        "primary_dark": "#0B1F3A",
        "accent": "#14B8A6"
      },
  
      "content": {
        "background": "#F8FAFC",
        "surface": "#FFFFFF",
        "border": "#E5E7EB"
      },
  
      "text": {
        "primary": "#111827",
        "secondary": "#6B7280",
        "muted": "#9CA3AF"
      },
  
      "status": {
        "success": "#22C55E",
        "warning": "#F59E0B",
        "danger": "#EF4444",
        "info": "#3B82F6",
        "neutral": "#6B7280"
      },
  
      "charts": {
        "primary": "#14B8A6",
        "secondary": "#7DD3FC",
        "tertiary": "#A7F3D0",
        "quaternary": "#67E8F9",
        "muted": "#CBD5E1"
      }
    },
  
    "spacing_system": {
      "base_unit": 8,
      "page_padding": 24,
      "section_gap": 20,
      "card_padding": 20,
      "card_gap": 16,
      "border_radius": 12
    },
  
    "typography": {
      "font_family": "Inter",
  
      "hierarchy": {
        "page_title": {
          "size": "32px",
          "weight": 700
        },
  
        "section_title": {
          "size": "18px",
          "weight": 600
        },
  
        "metric": {
          "size": "28px",
          "weight": 700
        },
  
        "table_value": {
          "size": "14px",
          "weight": 500
        },
  
        "body": {
          "size": "14px"
        },
  
        "caption": {
          "size": "12px"
        }
      }
    },
  
    "page_structure": {
      "header": {
        "layout": "horizontal",
  
        "left": [
          "page_title",
          "page_description"
        ],
  
        "right": [
          "date_range_filter",
          "team_filter",
          "primary_action"
        ]
      },
  
      "content_flow": [
        "executive_kpis",
        "analytics_row",
        "team_performance_section"
      ]
    },
  
    "executive_kpis": {
      "purpose": "Immediate operational health overview",
  
      "layout": {
        "type": "horizontal_metric_grid",
        "cards_per_row": 5
      },
  
      "card_structure": {
        "icon_left": true,
        "metric_primary": true,
        "trend_indicator": true
      },
  
      "guidelines": [
        "Equal-width cards.",
        "Focus on operational metrics.",
        "Avoid excessive detail.",
        "Support quick executive scanning."
      ]
    },
  
    "analytics_row": {
      "layout": {
        "type": "three_column",
        "distribution": "equal"
      },
  
      "components": [
        "pipeline_distribution_chart",
        "performance_trend_chart",
        "commission_trend_chart"
      ]
    },
  
    "chart_design_system": {
      "style": "Executive Analytics",
  
      "requirements": [
        "Minimal gridlines.",
        "Soft brand colours.",
        "Clean axis labels.",
        "No visual clutter.",
        "Focus on trend recognition.",
        "Consistent card styling."
      ],
  
      "chart_types": {
        "distribution": "donut_chart",
        "performance": "line_chart",
        "commission": "bar_chart"
      }
    },
  
    "team_performance_section": {
      "layout": {
        "type": "two_column",
        "ratio": "70/30"
      },
  
      "left": {
        "component": "team_performance_table"
      },
  
      "right": {
        "component": "operational_alerts"
      }
    },
  
    "team_performance_table": {
      "role": "Primary management workspace",
  
      "style": {
        "sticky_header": true,
        "hover_state": true,
        "selected_row": true,
        "minimal_borders": true
      },
  
      "columns": {
        "team_member": {
          "contains": [
            "avatar",
            "name"
          ]
        },
  
        "pipeline": {
          "contains": [
            "active_workload"
          ]
        },
  
        "activity": {
          "contains": [
            "viewings",
            "deals",
            "performance_metrics"
          ]
        },
  
        "financial": {
          "contains": [
            "commission",
            "conversion_metrics"
          ]
        },
  
        "trend": {
          "contains": [
            "mini_sparkline"
          ]
        },
  
        "actions": {
          "overflow_menu": true
        }
      }
    },
  
    "operational_alerts": {
      "layout": "vertical_stack",
  
      "spacing": 16,
  
      "components": [
        {
          "type": "follow_up_alerts"
        },
        {
          "type": "upcoming_schedule_alerts"
        },
        {
          "type": "closing_alerts"
        }
      ]
    },
  
    "alert_cards": {
      "style": {
        "compact": true,
        "high_visibility": true
      },
  
      "structure": {
        "icon": true,
        "metric": true,
        "cta_link": true
      }
    },
  
    "right_drawer": {
      "role": "Team Member Management Workspace",
  
      "structure": [
        "team_member_header",
        "tab_navigation",
        "information_cards",
        "action_footer"
      ]
    },
  
    "team_member_header": {
      "contains": [
        "avatar",
        "name",
        "status"
      ]
    },
  
    "drawer_tabs": {
      "style": "underline_navigation",
  
      "tabs": [
        "overview",
        "performance"
      ]
    },
  
    "information_cards": {
      "layout": "vertical_stack",
  
      "spacing": 16,
  
      "sections": [
        {
          "name": "contact_information",
          "layout": "key_value"
        },
        {
          "name": "commission_configuration",
          "layout": "key_value"
        },
        {
          "name": "targets",
          "layout": "key_value"
        },
        {
          "name": "manager_notes",
          "layout": "content_block"
        }
      ]
    },
  
    "team_management_rules": {
      "requirements": [
        "Selecting a team member updates the drawer instantly.",
        "Managers should never navigate away to edit team members.",
        "Agent settings should be editable within the drawer.",
        "Performance context should remain visible while editing."
      ]
    },
  
    "cards": {
      "background": "#FFFFFF",
      "border": "1px solid #E5E7EB",
      "radius": "12px",
      "shadow": "minimal",
      "padding": "20px"
    },
  
    "badges": {
      "style": "soft_filled",
      "shape": "pill",
  
      "usage": [
        "status",
        "performance_state",
        "team_member_state"
      ]
    },
  
    "component_patterns": {
      "manager_module": {
  
        "always_include": [
          "executive_kpis",
          "analytics_row",
          "team_table",
          "operational_alerts",
          "team_member_drawer"
        ],
  
        "avoid": [
          "deep_nested_navigation",
          "separate_team_member_pages",
          "overly_complex_bi_dashboards"
        ]
      }
    },
  
    "interaction_rules": [
      "Management insights should be visible immediately.",
      "Team member selection updates the drawer instantly.",
      "Charts support decisions, not exploration.",
      "Operational alerts should remain highly visible.",
      "Managers should be able to take action directly from the dashboard.",
      "Performance comparisons should be easy and intuitive.",
      "The drawer acts as a lightweight employee management console.",
      "Maintain consistency with all ROOMAH CRM modules."
    ],
  
    "responsive_behavior": {
      "desktop": {
        "three_panel_layout": true
      },
  
      "tablet": {
        "drawer_collapsible": true,
        "charts_stack_vertically": true
      },
  
      "mobile": {
        "single_column_layout": true,
        "drawer_bottom_sheet": true,
        "kpi_cards_scrollable": true
      }
    },
  
    "cursor_generation_rules": [
      "Follow the same ROOMAH master-detail architecture used in Leads, Properties, Campaigns, Viewings and Deals.",
      "Use the same colour palette and spacing system as all previous modules.",
      "Prioritise management visibility over operational execution.",
      "Keep charts simple and executive-friendly.",
      "Use the right drawer as the team member management workspace.",
      "Avoid creating separate employee detail pages.",
      "Make team performance comparison effortless.",
      "Keep operational alerts visible and actionable.",
      "Ensure the module feels like a management command centre rather than a reporting dashboard."
    ]
  }